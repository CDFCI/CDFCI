{
    "hamiltonian": {
        "type": "molecule",
        "molecule": {
            "fcidump_path": "../../../data/n2_cc-pvqz.fcidump",
            "threshold": 0.0
        }
    },
    "solver":{
        "type": "cdfci",
        "cdfci": {
            "num_iterations": 300000,
            "report_interval": 1000,
            "z_threshold": 5e-5,
            "z_threshold_search": false,
            "num_coordinates": 128,
            "stopping_dx_threshold": 1e-6,
            "save_configuration": true,
            "save_configuration_location": "/tmp/n2_ccpvqz.dump"
        }
    },
    "max_memory": 50
}
